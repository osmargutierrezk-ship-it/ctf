# ── Base de datos ─────────────────────────────────────────────────────────────
# Render PostgreSQL connection string (se configura automáticamente en Render)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# ── Aplicación ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL pública de la aplicación (para generar los links de QR)
# Ejemplo: https://ctf-app.onrender.com
APP_URL=https://tu-app.onrender.com

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Genera una clave secreta segura: openssl rand -base64 48
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_usa_openssl_rand_base64_48
